# ============================================================
# ENVIRONMENT
# ============================================================

NODE_ENV=development
APP_ENV=development
APP_URL=http://localhost:5173
API_URL=http://localhost:3000

# ============================================================
# FIREBASE CLIENT CONFIG (used by frontend)
# ============================================================

FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXX
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abcdef123456
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================================
# FIREBASE ADMIN (used by backend for JWT verification)
# ============================================================

FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# IMPORTANT:
# Store private key as a single line with escaped newlines (\n)
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqh...\n-----END PRIVATE KEY-----\n"

# Optional (if loading from JSON file instead)
# GOOGLE_APPLICATION_CREDENTIALS=./config/firebase-admin.json

# ============================================================
# AUTH / JWT SETTINGS
# ============================================================

# If using Firebase ID token directly (recommended)
AUTH_PROVIDER=firebase
AUTH_EXPECTED_AUDIENCE=your-project-id
AUTH_EXPECTED_ISSUER=https://securetoken.google.com/your-project-id

# Require verified email?
AUTH_REQUIRE_EMAIL_VERIFIED=true

# ============================================================
# OPTIONAL: Custom App JWT (if issuing your own token)
# ============================================================

# Only needed if you mint your own JWT after Firebase verification
APP_JWT_ISSUER=https://api.localhost
APP_JWT_AUDIENCE=https://api.localhost
APP_JWT_SECRET=super_long_random_secret_256_bit
APP_JWT_EXPIRES_IN=15m
APP_REFRESH_TOKEN_EXPIRES_IN=7d

# ============================================================
# SHOPIFY
# ============================================================

SHOPIFY_STORE_DOMAIN
SHOPIFY_ADMIN_ACCESS_TOKEN
SHOPIFY_STOREFRONT_ACCESS_TOKEN
STRIPE_SECRET_KEY

# ============================================================
# CORS / SECURITY
# ============================================================

CORS_ALLOWED_ORIGINS=http://localhost:5173
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=lax

# ============================================================
# FIREBASE EMULATOR (Optional for local development)
# ============================================================

FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIREBASE_USE_EMULATOR=false