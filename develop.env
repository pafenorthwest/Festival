# ============================================================
# ENVIRONMENT
# ============================================================

NODE_ENV=development
FRONT_APP_URL=http://localhost:5173
FRONT_API_URL=http://localhost:3000
APP_URL=http://localhost:5173
API_URL=http://localhost:3000

# ============================================================
# DATABASE
# ============================================================

DB_USER=festivaladmin
DB_PASSWORD=replace-me
DATABASE=festival_db
DB_HOST=localhost
DB_PORT=5432
DB_SSL=false
DB_SCHEMA=orgs

# ============================================================
# FRONTEND RUNTIME (used by the frontend)
# ============================================================

FRONT_API_BASE=http://localhost:3000
FRONT_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXX
FRONT_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FRONT_FIREBASE_PROJECT_ID=your-project-id
FRONT_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# ============================================================
# FIREBASE ADMIN (used by the backend)
# ============================================================

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# IMPORTANT:
# Store the private key as a single line with escaped newlines (\n)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqh...\n-----END PRIVATE KEY-----\n"

# Optional alternative to FIREBASE_CLIENT_EMAIL/FIREBASE_PRIVATE_KEY
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# ============================================================
# AUTH / LOCAL DEV BEHAVIOR
# ============================================================

AUTH_PROVIDER=firebase
AUTH_MODE=auto_provision
AUTH_REQUIRE_EMAIL_VERIFIED=true

# ============================================================
# FIREBASE AUTH EMULATOR (dev only)
# ============================================================

FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIREBASE_USE_EMULATOR=false
